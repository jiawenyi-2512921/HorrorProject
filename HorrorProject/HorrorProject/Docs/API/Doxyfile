# PROJECT_NAME = "HorrorProject API Documentation"
PROJECT_BRIEF = "Complete API reference for HorrorProject horror game framework"
PROJECT_NUMBER = 1.0

# Output configuration
OUTPUT_DIRECTORY = ./Generated
CREATE_SUBDIRS = NO

# Input configuration
INPUT = ../../Source/HorrorProject
FILE_PATTERNS = *.h *.cpp
RECURSIVE = YES
EXCLUDE_PATTERNS = */Private/* */ThirdParty/*

# Extraction settings
EXTRACT_ALL = YES
EXTRACT_PRIVATE = NO
EXTRACT_STATIC = YES
EXTRACT_LOCAL_CLASSES = YES
EXTRACT_ANON_NSPACES = NO

# Build settings
GENERATE_HTML = YES
GENERATE_LATEX = NO
GENERATE_XML = NO

# HTML output
HTML_OUTPUT = html
HTML_FILE_EXTENSION = .html
HTML_COLORSTYLE_HUE = 220
HTML_COLORSTYLE_SAT = 100
HTML_COLORSTYLE_GAMMA = 80
HTML_TIMESTAMP = YES
HTML_DYNAMIC_SECTIONS = YES

# Search engine
SEARCHENGINE = YES
SERVER_BASED_SEARCH = NO

# Diagrams
HAVE_DOT = YES
DOT_NUM_THREADS = 0
CLASS_DIAGRAMS = YES
CLASS_GRAPH = YES
COLLABORATION_GRAPH = YES
INCLUDE_GRAPH = YES
INCLUDED_BY_GRAPH = YES
CALL_GRAPH = NO
CALLER_GRAPH = NO
GRAPHICAL_HIERARCHY = YES
DIRECTORY_GRAPH = YES

# Source browsing
SOURCE_BROWSER = YES
INLINE_SOURCES = NO
STRIP_CODE_COMMENTS = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION = YES

# Preprocessing
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = NO
PREDEFINED = UCLASS() \
             USTRUCT() \
             UENUM() \
             UFUNCTION() \
             UPROPERTY() \
             GENERATED_BODY() \
             HORRORPROJECT_API

# Warnings
WARNINGS = YES
WARN_IF_UNDOCUMENTED = YES
WARN_IF_DOC_ERROR = YES
WARN_NO_PARAMDOC = YES

# Alphabetical index
ALPHABETICAL_INDEX = YES
COLS_IN_ALPHA_INDEX = 5

# Layout
LAYOUT_FILE = DoxygenLayout.xml
